# Grid frequency sensor (SEL-735 Power Quality Meter)
GRID_SENSOR_IP=192.168.1.100

# ASIC control (CGMiner API base URL)
ASIC_API_URL=http://192.168.1.200:4028

# MQTT broker for power sensors
MQTT_BROKER=localhost
MQTT_TOPIC=power/sensors

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Grafana
GRAFANA_HOST=localhost:3000
GRAFANA_API_KEY=

# Twilio SMS alerts (leave empty to disable SMS alerts)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
TWILIO_TO=

# Thresholds
ALERT_THRESHOLD=49.5
POLL_INTERVAL=10
ASIC_POWER=3.5

# Mining pool for connectivity check
MINING_POOL_HOST=pool.example.com

# Flask API
API_HOST=127.0.0.1
API_PORT=5000

# Max power safety ceiling in kW (default: 160 ASICs * 3.5 kW)
MAX_POWER=560

# Alert cooldown in seconds (prevents repeated SMS/Grafana alerts)
ALERT_COOLDOWN=300

# Mock mode (set to true to run without hardware for testing)
MOCK_MODE=false

# Log file path (default: mining_manager.log in working directory)
LOG_FILE=mining_manager.log

# Log format: "text" (default) or "json" (structured, for log aggregation)
LOG_FORMAT=text
